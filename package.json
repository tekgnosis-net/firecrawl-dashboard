{
  "name": "firecrawl-dashboard",
  "version": "1.0.0",
  "description": "A beautiful monitoring dashboard for self-hosted Firecrawl instances with Apple Design System styling",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently "npm run dev:server" "npm run dev:client"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "keywords": ["firecrawl", "dashboard", "monitoring", "web-scraping", "apple-design"],
  "author": "Tekgnosis Pty Ltd <info@tekgnosis.net>",
